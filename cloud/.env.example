# NeuroStack Cloud -- Required Environment Variables
# Copy to .env and fill in values before deployment

# === GCP ===
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# === Cloudflare R2 ===
NEUROSTACK_CLOUD_R2_ACCOUNT_ID=your-cloudflare-account-id
NEUROSTACK_CLOUD_R2_ACCESS_KEY_ID=your-r2-access-key
NEUROSTACK_CLOUD_R2_SECRET_ACCESS_KEY=your-r2-secret-key
NEUROSTACK_CLOUD_R2_BUCKET_NAME=neurostack-prod

# === Fireworks AI ===
NEUROSTACK_CLOUD_FIREWORKS_API_KEY=your-fireworks-api-key
NEUROSTACK_CLOUD_FIREWORKS_EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
NEUROSTACK_CLOUD_FIREWORKS_LLM_MODEL=accounts/fireworks/models/qwen2p5-7b-instruct

# === API Keys (JSON: {"sk-key1": {"user_id": "user-1", "tier": "free"}}) ===
NEUROSTACK_CLOUD_API_KEYS={}
