# NeuroStack Cloud -- Required Environment Variables
# Copy to .env and fill in values before deployment
# GCP-only stack: Cloud Run + Gemini API + Cloud Storage

# === GCP ===
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# === Cloud Storage ===
NEUROSTACK_CLOUD_GCS_BUCKET_NAME=neurostack-prod

# === Gemini API ===
NEUROSTACK_CLOUD_GEMINI_API_KEY=your-gemini-api-key
# NEUROSTACK_CLOUD_GEMINI_EMBED_MODEL=gemini-embedding-001
# NEUROSTACK_CLOUD_GEMINI_LLM_MODEL=gemini-2.5-flash
# NEUROSTACK_CLOUD_GEMINI_EMBED_DIM=768

# === API Keys (JSON: {"sk-key1": {"user_id": "user-1", "tier": "free"}}) ===
NEUROSTACK_CLOUD_API_KEYS={}
