# NeuroStack Cloud -- Required Environment Variables
# Copy to .env and fill in values before deployment
# GCP-only stack: Cloud Run + Vertex AI + Cloud Storage

# === GCP ===
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# === Cloud Storage ===
NEUROSTACK_CLOUD_GCS_BUCKET_NAME=neurostack-prod

# === Vertex AI ===
# Models are accessed via the Cloud Run service account (no API key needed).
# Override defaults only if using different models.
# NEUROSTACK_CLOUD_VERTEX_EMBED_MODEL=text-embedding-005
# NEUROSTACK_CLOUD_VERTEX_LLM_MODEL=gemini-2.0-flash

# === API Keys (JSON: {"sk-key1": {"user_id": "user-1", "tier": "free"}}) ===
NEUROSTACK_CLOUD_API_KEYS={}
